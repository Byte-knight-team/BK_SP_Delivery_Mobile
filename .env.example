# Backend API Base URL
#
# For Android Emulator (accesses host machine localhost):
#   EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080
#
# For iOS Simulator (accesses host machine localhost):
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
#
# For physical device (must be on same WiFi network as backend):
#   EXPO_PUBLIC_API_BASE_URL=http://<your-machine-ip>:8080
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080
